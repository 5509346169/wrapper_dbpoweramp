{
  "name": "wrapper-dbpoweramp-docs",
  "version": "0.1.0",
  "private": true,
  "description": "Documentation site for dBpoweramp Wrapper (Jekyll + locally bundled vendor).",
  "license": "MIT",
  "scripts": {
    "vendor": "node scripts/vendor-build.mjs",
    "check:cdn": "node scripts/check-no-cdn.mjs site",
    "deploy": "cpx \"_site/**/*\" \"site/\"",
    "clean": "rimraf site .jekyll-cache .jekyll-metadata"
  },
  "dependencies": {
    "esbuild": "0.20.2",
    "cpx2": "7.0.1"
  },
  "devDependencies": {
    "rimraf": "5.0.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "allowScripts": {
    "esbuild@0.20.2": true
  }
}
